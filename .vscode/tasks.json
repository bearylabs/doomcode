// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "compile (nix)",
			"type": "shell",
			"command": "nix develop -c npm run compile",
			"problemMatcher": "$tsc",
			"presentation": {
				"reveal": "silent"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "watch (nix)",
			"type": "shell",
			"command": "nix develop -c npm run watch",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never"
			}
		},
		{
			"label": "compile (local)",
			"type": "shell",
			"command": "npm.cmd",
			"args": [
				"run",
				"compile"
			],
			"options": {
				"shell": {
					"executable": "C:\\Windows\\System32\\cmd.exe",
					"args": [
						"/d",
						"/c"
					]
				}
			},
			"problemMatcher": "$tsc",
			"presentation": {
				"reveal": "silent"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "watch (local)",
			"type": "shell",
			"command": "npm.cmd",
			"args": [
				"run",
				"watch"
			],
			"options": {
				"shell": {
					"executable": "C:\\Windows\\System32\\cmd.exe",
					"args": [
						"/d",
						"/c"
					]
				}
			},
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never"
			}
		},
		{
			"label": "compile doom-workspace (nix)",
			"type": "shell",
			"command": "nix develop -c npm run compile",
			"options": {
				"cwd": "${workspaceFolder:doomcode-workspace}"
			},
			"problemMatcher": "$tsc",
			"presentation": {
				"reveal": "silent"
			}
		},
		{
			"label": "compile doom-workspace (local)",
			"type": "shell",
			"command": "npm.cmd",
			"args": [
				"run",
				"compile"
			],
			"options": {
				"cwd": "${workspaceFolder:doomcode-workspace}",
				"shell": {
					"executable": "C:\\Windows\\System32\\cmd.exe",
					"args": [
						"/d",
						"/c"
					]
				}
			},
			"problemMatcher": "$tsc",
			"presentation": {
				"reveal": "silent"
			}
		},
		{
			"label": "compile both (nix)",
			"dependsOrder": "parallel",
			"dependsOn": ["compile (nix)", "compile doom-workspace (nix)"],
			"group": "build"
		},
		{
			"label": "compile both (local)",
			"dependsOrder": "parallel",
			"dependsOn": ["compile (local)", "compile doom-workspace (local)"],
			"group": "build"
		},
		{
			"label": "install deps (local)",
			"type": "shell",
			"command": "npm.cmd",
			"args": [
				"install"
			],
			"options": {
				"shell": {
					"executable": "C:\\Windows\\System32\\cmd.exe",
					"args": [
						"/d",
						"/c"
					]
				}
			},
			"problemMatcher": []
		}
	]
}